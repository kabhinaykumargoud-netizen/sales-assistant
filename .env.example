# Copy this file to .env and fill in your values

# PostgreSQL connection string (provided by Railway automatically)
DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# JWT secret — use a long random string in production
JWT_SECRET="change_this_to_a_long_random_secret"

# Port (Railway sets this automatically)
PORT=3000

# Set to "production" on Railway
NODE_ENV=production

# Get from console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-..."

# Get from Meta Developer Portal → WhatsApp → Getting Started
WHATSAPP_TOKEN="EAAxxxxxxxxxxxxxxx"
WHATSAPP_PHONE_ID="your_phone_number_id"

# Any string you choose — must match what you enter in Meta webhook settings
WHATSAPP_VERIFY_TOKEN="your_verify_token"
